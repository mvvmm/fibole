{
  "name": "fibole",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply fibole-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply fibole-db --remote",
    "generate": "tsx scripts/generate-questions.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@cloudflare/vite-plugin": "^1.42.1",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^16.6.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
